NODE_ENV=development

PORT=3000

API_PREFIX=api/v1



DB_HOST=localhost

DB_PORT=5432

DB_USERNAME=egip

DB_PASSWORD=egip_secret

DB_DATABASE=egip



JWT_SECRET=egip-dev-secret-change-in-production

JWT_EXPIRES_IN=8h



REDIS_HOST=localhost

REDIS_PORT=6379



CORS_ORIGIN=http://localhost:5173



# Bill delivery: handoff = open device apps | live = send via gateways below

BILL_NOTIFY_MODE=handoff



# Email — SMTP (recommended for VPS demo)

SMTP_HOST=

SMTP_PORT=587

SMTP_USER=

SMTP_PASS=

SMTP_FROM=alerts@yourdomain.com

SMTP_SECURE=false



# SMS — generic HTTP gateway (any provider with JSON POST)

SMS_GATEWAY_URL=

SMS_GATEWAY_API_KEY=



# SMS — MSG91 (India, recommended)

MSG91_AUTH_KEY=

MSG91_SENDER_ID=EGIPIN

MSG91_ROUTE=4



# SMS / WhatsApp — Twilio (alternative)

TWILIO_ACCOUNT_SID=

TWILIO_AUTH_TOKEN=

TWILIO_SMS_FROM=

TWILIO_WHATSAPP_FROM=whatsapp:+14155238886



# WhatsApp — Meta Cloud API (alternative)

WHATSAPP_CLOUD_TOKEN=

WHATSAPP_PHONE_NUMBER_ID=



# Email — SendGrid (recommended)

SENDGRID_API_KEY=

SENDGRID_FROM=billing@yourdomain.com



# Email — Mailgun (alternative)

MAILGUN_API_KEY=

MAILGUN_DOMAIN=

# Jal Mitra AI — auto | live | off (auto uses OpenAI when OPENAI_API_KEY is set)
JAL_MITRA_LLM_MODE=auto
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini

# Consumer portal OTP — optional | required | off
CONSUMER_PORTAL_OTP_MODE=optional

# Payment gateway — Razorpay (UPI / QR / cards / net banking on mobile billing)
# Leave blank to use built-in demo gateway in development
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
PAYMENT_GATEWAY_MERCHANT_NAME=Uttarakhand Jal Sansthan

