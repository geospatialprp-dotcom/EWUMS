# Copy to deploy/hostinger-kvm/.env on the VPS:
#   cp .env.production.example .env && nano .env

# ── Public site ──────────────────────────────────────────────────────────────
# Your public URL (no trailing slash) — used for CORS
CORS_ORIGIN=https://YOUR_DOMAIN

# Google Map Tiles API key (optional; baked into frontend at build time)
VITE_GOOGLE_MAPS_API_KEY=

# ── Database (postgres service) ─────────────────────────────────────────────
DB_USERNAME=egip
DB_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
DB_DATABASE=egip

# API reads these via env_file (DB_HOST/REDIS_HOST overridden in compose)
DB_HOST=postgres
DB_PORT=5432
REDIS_HOST=redis
REDIS_PORT=6379

# ── API ───────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
API_PREFIX=api/v1

# Generate: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_RANDOM_64_CHAR_HEX
JWT_EXPIRES_IN=8h

# ── Notifications (optional) ──────────────────────────────────────────────────
BILL_NOTIFY_MODE=handoff
MSG91_AUTH_KEY=
MSG91_SENDER_ID=EGIPIN
MSG91_ROUTE=4
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SMS_FROM=
TWILIO_WHATSAPP_FROM=
WHATSAPP_CLOUD_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
SENDGRID_API_KEY=
SENDGRID_FROM=billing@yourdomain.com
MAILGUN_API_KEY=
MAILGUN_DOMAIN=

# ── AI / payments (optional) ──────────────────────────────────────────────────
JAL_MITRA_LLM_MODE=auto
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
CONSUMER_PORTAL_OTP_MODE=optional
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
PAYMENT_GATEWAY_MERCHANT_NAME=Uttarakhand Jal Sansthan

# ── GeoServer (only if using: --profile gis) ─────────────────────────────────
GEOSERVER_ADMIN_USER=admin
GEOSERVER_ADMIN_PASSWORD=CHANGE_ME_GEOSERVER_PASSWORD
